# =====================================================
# Executive Financial Dashboard
# Git Ignore Rules
# =====================================================

# -----------------------------------------------------
# Visual Studio Code
# -----------------------------------------------------
.vscode/

# -----------------------------------------------------
# Windows system files
# -----------------------------------------------------
Thumbs.db
Desktop.ini

# -----------------------------------------------------
# Temporary files
# -----------------------------------------------------
*.tmp
*.temp
*.bak

# -----------------------------------------------------
# Log files
# -----------------------------------------------------
*.log

# -----------------------------------------------------
# Power BI temporary files
# -----------------------------------------------------
*.pbix.autosave

# -----------------------------------------------------
# Python cache (for future development)
# -----------------------------------------------------
__pycache__/
*.pyc

# -----------------------------------------------------
# Jupyter Notebook checkpoints
# -----------------------------------------------------
.ipynb_checkpoints/